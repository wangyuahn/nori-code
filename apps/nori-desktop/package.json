{
  "name": "@nori-code/nori-desktop",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Nori Code desktop client — an Electron shell with Nori Dashboard, Vault browser, and Swarm visualization.",
  "author": "Nori Code",
  "homepage": "https://github.com/nori-code/nori-code",
  "type": "module",
  "main": "out/main.cjs",
  "scripts": {
    "build": "tsdown",
    "start": "electron .",
    "dev": "tsdown && electron .",
    "typecheck": "tsc --noEmit",
    "dist": "tsdown && electron-builder --config electron-builder.config.cjs"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "25.1.8",
    "tsdown": "0.22.0",
    "typescript": "6.0.2"
  }
}
