{
  "name": "@nori-code/migration-legacy",
  "version": "0.1.15",
  "description": "One-time migration helpers for importing legacy Kimi CLI data into Nori Code.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "files": [
    "dist"
  ],
  "imports": {
    "#/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nori-code/agent-core": "workspace:^",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nori-code/kaos": "workspace:^"
  }
}
